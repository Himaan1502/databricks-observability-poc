# Normalize line endings. Critical: shell scripts and cloud-init run on Linux
# Databricks/VM nodes, so they must stay LF even when edited on Windows.
* text=auto eol=lf

*.sh    text eol=lf
*.tftpl text eol=lf
*.tf    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Binaries
*.jar binary
*.png binary
*.jpg binary
