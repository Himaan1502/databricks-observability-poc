# Copy to .env and `source .env` before running terraform.

# --- Databricks auth (host + PAT) ---
export DATABRICKS_HOST="https://<your-workspace>.cloud.databricks.com"
export DATABRICKS_TOKEN="dapiXXXXXXXXXXXXXXXXXXXXXXXX"

# --- POC inputs ---
# host:port where the docker stack's Pushgateway is reachable FROM the cluster
export TF_VAR_prometheus_pushgateway_host="10.0.0.5:9091"

# Optional, only if enabling the Pyroscope/APM path
export TF_VAR_pyroscope_host="10.0.0.5:4040"
